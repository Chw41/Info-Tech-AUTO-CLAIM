MS_EMAIL=your_account@company.com
MS_PASSWORD=your_password

# true: show the browser window
HEADFUL=true

# true: force a fresh login and ignore the saved session
FORCE_LOGIN=false

# true: parse files only and do not submit to CloudHR
DRY_RUN=false

# target page after login
CLAIM_URL=https://v2.infotech-cloudhr.com.sg/ECLaim/ClaimApply.aspx

# base directory for claim folders; defaults to the project directory
CLAIMS_BASE_DIR=
